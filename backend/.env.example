# Server configuration
PORT=5000
NODE_ENV=development
# Database configuration
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/your_db_name?retryWrites=true&w=majority
# JWT token secret
JWT_SECRET=your_jwt_secret_key_change_me_to_something_random
# Frontend integration URL
FRONTEND_URL=http://localhost:5173
# Cloudinary credentials for media sharing (images, PDFs, documents)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret