{
  "name": "convohi",
  "version": "1.0.0",
  "description": "Modern MERN Real-Time Chat Application",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "server": "nodemon backend/server.js",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && npm install --prefix backend --legacy-peer-deps && npm install --prefix frontend --legacy-peer-deps",
    "build": "npm run install-all && npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  },
  "dependencies": {
    "mongodb": "^7.4.0"
  }
}
